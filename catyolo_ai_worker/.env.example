# Camera RTSP URL is built from each scene's camera_ip_address/camera_port/
# camera_username/camera_password (fetched from the backend's /scene/internal/
# endpoint). There is no RTSP_URL env var anymore — configure cameras in the UI.
API_BASE=http://localhost:8100
ENABLE_STREAM=true
STREAM_PORT=5001
YOLO_CONFIDENCE_THRESHOLD=0.4
HAILORT_LOGGER_PATH=/home/patryk/.local/share/catyolo/logs/hailort.log
ENABLE_SAMPLE_SAVER=false
SAMPLES_DIR=./samples
CONFIG_POLL_INTERVAL=2.0
ACTIONS_POLL_INTERVAL=2.0

# WS2 — Multi-camera: max simultaneous feeds (must match backend MAX_SCENES).
# The worker starts at most this many per-scene pipelines; extra scenes are skipped.
MAX_SCENES=3
# Per-scene pipeline target FPS. Lower this (e.g. 10) when running 3 feeds on
# one Hailo chip so the HailoRT ROUND_ROBIN scheduler isn't over-subscribed.
TARGET_FPS=30

# WS1 — Hailo abstraction layer
# hailo10h (default) or hailo8; leave unset to auto-detect via hailortcli
HAILO_ARCH=hailo10h
# Directory containing per-arch HEF manifests (hefs/<arch>/manifest.yaml)
HEF_DIR=./hefs

# WS4 — Auth: generate key with: uv run python ../catyolo_ai_backend/scripts/create_api_key.py
API_KEY=

# WS5 — Logging: optional file output (journald covers this when running under systemd)
LOG_LEVEL=INFO
LOG_FILE_PATH=
