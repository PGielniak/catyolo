# CatYolo frontend (serve.py) configuration — copy to .env and fill in values.

# Port the frontend proxy serves on.
FRONTEND_PORT=3100

# Backend API port (the frontend proxies API calls here).
BACKEND_PORT=8100

# Path to the built Vite dist folder.
FRONTEND_DIST=./dist

# Set to true to skip the API key prompt in the UI (development convenience only).
SKIP_AUTH=false
