# CatYolo worker configuration
# Generated by deploy/install.sh

# Backend API base URL.
API_BASE=${API_BASE}

# Authentication (sent as X-API-Key header).
API_KEY=${API_KEY}

# Multi-camera / performance settings.
MAX_SCENES=${MAX_SCENES}
TARGET_FPS=${TARGET_FPS}

# Hailo settings. Leave HAILO_ARCH empty to auto-detect from the device.
HAILO_ARCH=${HAILO_ARCH}
HEF_DIR=${HEF_DIR}
EXIT_ON_NO_HAILO=${EXIT_ON_NO_HAILO}
HAILO8_MAX_STREAMS=${HAILO8_MAX_STREAMS}

# Detection tuning.
YOLO_CONFIDENCE_THRESHOLD=${YOLO_CONFIDENCE_THRESHOLD}

# Optional debug MJPEG stream (one port serves all scenes on /feed/{scene_id}).
ENABLE_STREAM=${ENABLE_STREAM}
STREAM_PORT=${WORKER_STREAM_PORT}

# Optional sample saver.
ENABLE_SAMPLE_SAVER=${ENABLE_SAMPLE_SAVER}
SAMPLES_DIR=${SAMPLES_DIR}

# Polling intervals for backend configuration and actions.
CONFIG_POLL_INTERVAL=${CONFIG_POLL_INTERVAL}
ACTIONS_POLL_INTERVAL=${ACTIONS_POLL_INTERVAL}

# Logging. Under systemd, journald captures stdout; set LOG_FILE_PATH to also
# write to a file.
LOG_LEVEL=${LOG_LEVEL}
LOG_FILE_PATH=${LOG_FILE_PATH}

# HailoRT internal log destination.
HAILORT_LOGGER_PATH=${HAILORT_LOGGER_PATH}
