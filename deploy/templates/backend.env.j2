# CatYolo backend configuration
# Generated by deploy/install.sh

DATABASE_PATH=${DATABASE_PATH}
LOG_FILE_PATH=${LOG_FILE_PATH}
LOG_LEVEL=${LOG_LEVEL}

# Camera credentials fallback for the /frame endpoint.
CAMERA_USERNAME=${CAMERA_USERNAME}
CAMERA_PASSWORD=${CAMERA_PASSWORD}

# Security: stable random salt. Changing it invalidates existing API keys.
API_KEY_SALT=${API_KEY_SALT}

# Set to true to disable API key authentication (frontend + backend).
# Intended for development / trusted local networks only.
SKIP_AUTH=${SKIP_AUTH}

# CORS: comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}

# Maximum number of scenes (cameras) stored. Must match the worker's MAX_SCENES.
MAX_SCENES=${MAX_SCENES}

# Bind address and port for the backend API.
BACKEND_HOST=${BACKEND_HOST}
BACKEND_PORT=${BACKEND_PORT}
