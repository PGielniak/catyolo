# CatYolo frontend (serve.py) configuration
# Generated by deploy/install.sh

# Port the frontend proxy serves on.
FRONTEND_PORT=${FRONTEND_PORT}

# Backend API port (the frontend proxies /scene, /action, /log, /api_key, /frame here).
